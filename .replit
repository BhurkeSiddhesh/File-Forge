modules = ["python-3.12", "nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "imagemagickBig", "jbig2dec", "libaom", "libde265", "libheif", "mupdf", "nasm", "oneDNN", "openssl", "qpdf", "re2", "x265", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export LD_LIBRARY_PATH=/nix/store/3h9y320bxdxs0byqzkkqmbcl5yip4cf8-gcc-15.1.0-lib/lib:$LD_LIBRARY_PATH && uvicorn main:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "export LD_LIBRARY_PATH=/nix/store/3h9y320bxdxs0byqzkkqmbcl5yip4cf8-gcc-15.1.0-lib/lib:$LD_LIBRARY_PATH && gunicorn --bind=0.0.0.0:5000 --reuse-port --worker-class uvicorn.workers.UvicornWorker main:app"]
